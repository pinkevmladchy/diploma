# PostgreSQL connection string used by Prisma at runtime
# Local PostgreSQL: database "diploma" must exist and be reachable with these credentials.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/diploma?schema=public"

# HTTP server
PORT=4000
NODE_ENV=development

# JWT secrets (replace with strong values in real deployments)
JWT_ACCESS_SECRET="change-me-access"
JWT_REFRESH_SECRET="change-me-refresh"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# Bcrypt rounds for password hashing
BCRYPT_ROUNDS=10

# Default admin created by the seed script
SEED_ADMIN_EMAIL="admin@smart-home.local"
SEED_ADMIN_PASSWORD="admin12345"
SEED_ADMIN_NAME="Адміністратор"
